# Токен вашего Telegram-бота, полученный от @BotFather
TELEGRAM_BOT_TOKEN="123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ"

# ID вашей приватной группы (обязательно с минусом)
TELEGRAM_CHAT_ID="-0123456789"

# Путь к последовательному порту ноды
SERIAL_PORT="/dev/ttyUSB0"

# Задержка перед повторной попыткой подключения к USB (в секундах)
RECONNECT_DELAY="15"

# --- Настройки топиков (Message Thread IDs) ---
# Топик для общего широковещательного канала (ch 0).
# Оставьте пустым для использования General топика группы.
TOPIC_GENERAL=""

# ID конкретной портативной ноды, которую вы носите с собой (например, "!abcdef12")
# Если хотите выделять в отдельный топик ЛС вообще от всех, оставьте пустым или "ALL"
MY_PORTABLE_NODE_ID="!abcdef12"

# Топик для личных сообщений (Direct Messages) от вашей портативной ноды
TOPIC_MY_DIRECT="123"

# Топик для всех остальных личных сообщений (Direct Messages)
TOPIC_OTHER_DIRECT="124"

# Топик для служебных сообщений бота (старт/стоп)
TOPIC_SYSTEM="125"
